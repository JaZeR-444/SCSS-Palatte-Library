{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash([LINT_COMMAND])",
      "Bash([TEST_COMMAND])",
      "Bash([BUILD_COMMAND])",
      "Read(./**)",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./private/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/secret-scan.sh ${CLAUDE_PROJECT_DIR}" }
        ]
      }
    ]
  }
}
